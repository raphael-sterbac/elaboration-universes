data Nat : U 0 where {
  zero : Nat ;
  succ : Nat -> Nat
} ;

data List (A : Tp) : Tp where {
  nil : List A ;
  cons : A -> List A -> List A
} ;

let UniverseList : Tp = List (U 1) ;

let myTypes : List (U 2) = cons (U 2) (U 0) (cons (U 2) (Nat -> Nat) (cons (U 2) (UniverseList) (nil (U 2)))) ;

let headTy : List (U 2) -> U 2 = \l.
  elimList (U 2) (\_. U 2)
    < \p ihs. U 0 ,         
    < \p ihs. fst p ,     
    * > >
    l ;

let extractedType : headTy myTypes = Nat ;

let myVal : extractedType = zero ;

