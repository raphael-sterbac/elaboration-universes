data Nat : Tp where {
  zero : Nat ;
  succ : Nat -> Nat
} ;

data List (A : Tp) : Tp where {
  nil : List A ;
  cons : A -> List A -> List A
} ;

data Monad : Tp where {
  mkMonad : (M : Tp -> Tp) ->
            (ret : (A : Tp) -> A -> M A) ->
            (bind : (A : Tp) -> (B : Tp) -> M A -> (A -> M B) -> M B) ->
            Monad
} ;

let listRet : (A : Tp) -> A -> List A = \A x.
  cons A x (nil A) ;

let append : (B : Tp) -> List B -> List B -> List B = \B l1 l2.
  elimList B (\_. List B)
    < \p ihs. l2 ,
    < \p ihs. cons B (fst p) (fst ihs) ,
    * > >
    l1 ;

let listBind : (A : Tp) -> (B : Tp) -> List A -> (A -> List B) -> List B = \A B l f.
  elimList A (\_. List B)
    < \p ihs. nil B ,
    < \p ihs. append B (f (fst p)) (fst ihs) ,
    * > >
    l ;

let ListMonad : Monad = mkMonad List listRet listBind ;

let duplicate : Nat -> List Nat = \x.
  cons Nat x (cons Nat x (nil Nat)) ;

let mylist : List Nat = cons Nat zero (cons Nat (succ zero) (nil Nat)) ;

listBind Nat Nat mylist duplicate