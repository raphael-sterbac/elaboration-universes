data Nat : Tp where {
  zero : Nat ;
  succ : Nat -> Nat
} ;

data List (A : Tp) : Tp where {
  nil : List A ;
  cons : A -> List A -> List A
} ;

let Monad : Tp = {
  M : Tp -> Tp,
  ret : (A : Tp) -> A -> M A,
  bind : (A : Tp) -> (B : Tp) -> M A -> (A -> M B) -> M B
} ;

let append : (B : Tp) -> List B -> List B -> List B = \B l1 l2.
  elimList B (\_. List B)
    < \p ihs. l2 ,
    < \p ihs. cons B (fst p) fst ihs ,
    * > >
    l1 ;

let ListMonad : Monad = {
  M = \A. List A,
  ret = \A x. cons A x (nil A),
  bind = \A B l f.
    elimList A (\_. List B)
      < \p ihs. nil B ,
      < \p ihs. append B (f (fst p)) fst ihs ,
      * > >
      l
} ;

let mapM : (m : Monad) -> (A : Tp) -> (B : Tp) -> (A -> B) -> m.M A -> m.M B = \m A B f ma.
  m.bind A B ma (\a. m.ret B (f a)) ;

let Database : U 1 = {
  activeIds : List Nat
} ;

let myDb : Database = {
  activeIds = cons Nat zero (cons Nat (succ zero) (nil Nat))
} ;

mapM ListMonad Nat Nat (\x. succ x) myDb.activeIds